# ========================================
# AI导航平台环境变量配置（示例）
# 复制为 .env 或 .env.local 并按需修改
# ========================================

# 应用基础配置
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 页脚展示版本号（可选，不填则使用 package.json 的 version）
# NEXT_PUBLIC_APP_VERSION=1.0.0

# 数据库配置
DATABASE_URL=postgresql://localhost:5432/local.db

# Clerk认证配置 (可选，暂时不启用)
# CLERK_SECRET_KEY=your_clerk_secret_key_here
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# 分析工具配置 (可选)
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# 监控工具配置 (可选)
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=your_better_stack_token_here
# NEXT_PUBLIC_BETTER_STACK_INGESTING_HOST=in.logs.betterstack.com

# Sentry错误监控配置 (可选)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
# SENTRY_ORGANIZATION=your_sentry_organization
# SENTRY_PROJECT=your_sentry_project

# Arcjet安全配置 (可选)
# ARCJET_KEY=your_arcjet_key_here

# Google Analytics 4 测量 ID（G-xxxxxxxx）
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-SD3JQVC25K
# 百度统计站点 id（hm.js 参数中的数字）
NEXT_PUBLIC_BAIDU_TONGJI_ID=969b089e87ca4b02f96f2c1ee3553b06


# 开发工具配置
ANALYZE=false
NEXT_PUBLIC_SENTRY_DISABLED=true

# 部署配置
VERCEL_URL=
VERCEL_ENV=
VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_BYPASS_TOKEN=

# 测试配置
CI=false

